# ==============================================================================
# Manna LLM Aster Crypto Trader - Environment Variables
# Copy to .env.local and fill in values
# ==============================================================================

# --- Aster DEX API (required for market data) ---
ASTER_API_KEY=
ASTER_SECRET_KEY=

# --- LLM Provider ---
# 'groq' = free cloud API (works on Vercel)
# 'ollama' = local GPU (for development with RTX/Apple Silicon)
LLM_PROVIDER=groq

# Groq (sign up free at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=deepseek-r1-distill-llama-70b

# Ollama (local only — ignored when LLM_PROVIDER=groq)
# OLLAMA_BASE_URL=http://localhost:11434
# DEEPSEEK_MODEL=deepseek-r1:14b

# --- Database (PostgreSQL) ---
# Neon (free via Vercel dashboard) or Supabase
# Leave blank to run without persistence (trades stay in-memory only)
DATABASE_URL=
# SSL is auto-detected for Neon/Supabase URLs; override here if needed:
# DATABASE_SSL=true

# --- Trading ---
TRADING_SIMULATION_MODE=true
# Optional: paper preset (conservative | balanced | aggressive) - overrides thresholds in simulation only
# PAPER_PRESET=balanced
# Lower these for more simulation/demo trades; raise for live trading.
# TRADING_CONFIDENCE_THRESHOLD=0.70
# TRADING_MIN_OPPORTUNITY_SCORE=50
# TRADING_STOP_LOSS=3.0
# Optional: protect /api/cron/trading-cycle when using external cron (e.g. cron-job.org)
# CRON_SECRET=your-secret-here
# Optional: protect public endpoints (e.g. /api/public/*) with key + rate limit (60/min)
# PUBLIC_API_KEY=your-secret-key
# Notifications: Discord or any webhook when a trade opens/closes
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# NOTIFICATION_WEBHOOK_URL=https://your-server.com/webhook
# Telegram: create bot via @BotFather, set TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID for trade + daily report
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Circuit breaker: stop opening new trades if today's loss exceeds (0 = disabled)
# MAX_DAILY_LOSS_PERCENT=10
# MAX_DAILY_LOSS_USD=0
# TRADING_TAKE_PROFIT=7.5
# MAX_CONCURRENT_POSITIONS=2

# ==============================================================================
# ALPACA MARKETS — Traditional Finance (Stocks, ETFs)
# Sign up free at https://alpaca.markets — paper trading requires no deposit
# ==============================================================================

# Get your keys at: https://app.alpaca.markets/paper-dashboard (paper)
#                   https://app.alpaca.markets/live-dashboard  (live)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Paper mode (true = paper trading / no real money, default and recommended)
ALPACA_PAPER=true

# Asset class to trade: 'crypto' | 'equity' | 'both' (default: crypto)
# Set to 'both' to run the agent pipeline against both markets simultaneously
TRADING_ASSET_CLASS=crypto

# Stock-specific overrides (optional — EQUITY_CONSTANTS defaults used if omitted)
# EQUITY_STOP_LOSS_PCT=1.5
# EQUITY_TAKE_PROFIT_PCT=3.5
# EQUITY_MIN_SCORE=60
